# Used by `npm run sync-sheet` to import Google Form responses into data/businesses.json.
# The form's responses sheet must be set to "Anyone with the link → Viewer" in Google Sheets.

# Sheet ID — the long string in the URL between /spreadsheets/d/ and /edit
GOOGLE_SHEET_ID=

# GID of the responses tab — the number after gid= in the URL. Defaults to 0 (first tab).
GOOGLE_SHEET_GID=0
